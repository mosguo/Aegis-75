# ===== 核心角色 =====
AEGIS_ROLE=control-plane
AEGIS_HOST_CLASS=byoh
AEGIS_DEPLOYMENT_TARGET=zeabur

# ===== 網路 =====
AEGIS_BIND_ADDR=0.0.0.0:8080
PORT=8080

# ===== BYOH =====
AEGIS_BYOH_ENABLED=true
AEGIS_HUB_MODE=data-execution-hub

# ===== Logging =====
AEGIS_LOG_LEVEL=info
AEGIS_HEARTBEAT_ENABLED=true
AEGIS_HEARTBEAT_INTERVAL_SECS=30

# ===== Execution =====
AEGIS_EXECUTION_MODE=paper
AEGIS_MARKET_SCOPE=cex+dex-75
AEGIS_EXCHANGES=binance,okx,bybit,coinbase,kraken,gate
AEGIS_DEX_NETWORKS=ethereum,arbitrum,base,bnb-chain,solana

# ===== Signing =====
AEGIS_SIGNING_MODE=disabled

# ===== ZeroClaw =====
ZEROCLAW_ENABLED=false
# ZEROCLAW_GATEWAY_URL=https://your-gateway
# ZEROCLAW_API_KEY=your-key

# ===== Identity =====
AEGIS_NODE_ID=zeabur-node
AEGIS_REGION=global-sim
AEGIS_CLUSTER=aegis-75
AEGIS_LOGICAL_HOST_ID=aegis-node-logical-01
AEGIS_RUNTIME_HOST_ID=aegis-node-runtime-01
AEGIS_LOGICAL_SITE=zeabur-sim

# ===== BYOH future =====
AEGIS_PHYSICAL_HOST_PLANNED=true
# AEGIS_PHYSICAL_HOST_ID=cht-host-01

# ===== Tuning =====
AEGIS_ZERO_COPY=true
AEGIS_HUGEPAGES=false
AEGIS_CPU_AFFINITY=false